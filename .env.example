# Copy to .env (kept in landing/) and fill in values.

# AWS (optional overrides)
AWS_PROFILE=aiready
AWS_REGION=ap-southeast-2

# Domain
DOMAIN_NAME=getaiready.dev

# Notifications
SES_TO_EMAIL=caopengau@gmail.com
SES_FROM_EMAIL=notifications@getaiready.dev

# Set to true to manage SES domain identity in non-production stages.
# Production stage manages domain identity by default.
SES_MANAGE_DOMAIN_IDENTITY=false

# Cloudflare DNS (required for custom domain automation)
# Token permissions: Zone:Read, Zone:DNS:Edit (limit to getaiready.dev zone)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_ZONE_ID=your_zone_id

# VS Code Extension Publishing
# Get from: https://dev.azure.com -> User Settings -> Personal Access Tokens
# Permissions: Marketplace > Manage
