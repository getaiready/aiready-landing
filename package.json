{
  "name": "@aiready/landing",
  "version": "0.10.5",
  "private": true,
  "scripts": {
    "dev": "next dev -p 8887 --webpack",
    "blog-audit": "node scripts/audit-blogs.js",
    "build": "pnpm blog-audit && next build && node scripts/post-build.js",
    "start": "next start",
    "lint": "eslint app components lib content scripts e2e",
    "clean": "rm -rf .next out",
    "test:e2e": "playwright test",
    "deploy:sst": "sst deploy --yes",
    "deploy:sst:prod": "sst deploy --stage production --yes",
    "deploy:dev": "sst deploy --stage dev --yes",
    "deploy:prod": "sst deploy --stage production --yes",
    "deploy:remove": "sst remove --yes",
    "type-check": "tsc --noEmit",
    "format-check": "prettier --check . --ignore-path ../../.prettierignore",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@aiready/components": "workspace:*",
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/client-ses": "^3.1024.0",
    "@aws-sdk/client-sesv2": "^3.1024.0",
    "@aws-sdk/client-sns": "^3.1024.0",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "marked": "^18.0.0",
    "next": "16.2.4",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "10.2.1",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
